*.pyc
.venv/
import sys
import json
from datetime import datetime
from PyQt6.QtWidgets import (QApplication, QWidget, QVBoxLayout, QHBoxLayout, 
                             QLineEdit, QPushButton, QTableWidget, QTableWidgetItem, 
                             QMessageBox, QCheckBox, QLabel, QHeaderView)

class WeatherDiary(QWidget):
    def __init__(self):
        super().__init__()
        self.data = []
        self.init_ui()
        self.load_data()

    def init_ui(self):
        self.setWindowTitle("Weather Diary")
        self.setGeometry(100, 100, 600, 450)
        layout = QVBoxLayout()

        # Поля ввода
        input_layout = QHBoxLayout()
        self.date_input = QLineEdit(placeholderText="ДД.ММ.ГГГГ")
        self.temp_input = QLineEdit(placeholderText="Температура (°C)")
        self.desc_input = QLineEdit(placeholderText="Описание")
        self.precip_cb = QCheckBox("Осадки")
        
        input_layout.addWidget(self.date_input)
        input_layout.addWidget(self.temp_input)
        input_layout.addWidget(self.desc_input)
        input_layout.addWidget(self.precip_cb)
        layout.addLayout(input_layout)

        # Кнопки
        btn_add = QPushButton("Добавить запись")
        btn_add.clicked.connect(self.add_entry)
        layout.addWidget(btn_add)

        # Фильтры
        filter_layout = QHBoxLayout()
        self.filter_temp = QLineEdit(placeholderText="Мин. темп. для фильтра")
        btn_filter = QPushButton("Фильтровать (> t)")
        btn_filter.clicked.connect(self.apply_filter)
        btn_reset = QPushButton("Сброс")
        btn_reset.clicked.connect(self.update_table)
        
        filter_layout.addWidget(self.filter_temp)
        filter_layout.addWidget(btn_filter)
        filter_layout.addWidget(btn_reset)
        layout.addLayout(filter_layout)

        # Таблица
        self.table = QTableWidget(0, 4)
        self.table.setHorizontalHeaderLabels(["Дата", "Темп.", "Описание", "Осадки"])
        self.table.horizontalHeader().setSectionResizeMode(QHeaderView.ResizeMode.Stretch)
        layout.addWidget(self.table)

        self.setLayout(layout)

    def add_entry(self):
        date = self.date_input.text()
        temp = self.temp_input.text()
        desc = self.desc_input.text()
        precip = "Да" if self.precip_cb.isChecked() else "Нет"

        # Валидация
        try:
            datetime.strptime(date, "%d.%m.%Y")
            float(temp)
            if not desc.strip(): raise ValueError()
        except ValueError:
            QMessageBox.warning(self, "Ошибка", "Проверьте формат данных!\nДата: ДД.ММ.ГГГГ\nТемп: число\nОписание: не пусто")
            return

        entry = {"date": date, "temp": float(temp), "desc": desc, "precip": precip}
        self.data.append(entry)
        self.save_data()
        self.update_table()
        
        # Очистка полей
        self.temp_input.clear()
        self.desc_input.clear()

    def update_table(self, display_data=None):
        items = display_data if display_data is not None else self.data
        self.table.setRowCount(0)
        for entry in items:
            row = self.table.rowCount()
            self.table.insertRow(row)
            self.table.setItem(row, 0, QTableWidgetItem(entry['date']))
            self.table.setItem(row, 1, QTableWidgetItem(str(entry['temp'])))
            self.table.setItem(row, 2, QTableWidgetItem(entry['desc']))
            self.table.setItem(row, 3, QTableWidgetItem(entry['precip']))

    def apply_filter(self):
        try:
            min_t = float(self.filter_temp.text())
            filtered = [e for e in self.data if e['temp'] > min_t]
            self.update_table(filtered)
        except ValueError:
            QMessageBox.critical(self, "Ошибка", "Введите число для фильтра")

    def save_data(self):
        with open("weather_data.json", "w", encoding="utf-8") as f:
            json.dump(self.data, f, ensure_ascii=False, indent=4)

    def load_data(self):
        try:
            with open("weather_data.json", "r", encoding="utf-8") as f:
                self.data = json.load(f)
                self.update_table()
        except FileNotFoundError:
            self.data = []

if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = WeatherDiary()
    window.show()
    sys.exit(app.exec())
